{
  "singleQuote": true,
  "semi": true,
  "trailingComma": "all",
  "arrowParens": "always",
  "tabWidth": 2,
  "printWidth": 100,
  "endOfLine": "lf",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "singleAttributePerLine": true,
  "htmlWhitespaceSensitivity": "strict",
  "embeddedLanguageFormatting": "off",
  "proseWrap": "always",
  "plugins": [
    "@trivago/prettier-plugin-sort-imports",
    "prettier-plugin-tailwindcss",
    "prettier-plugin-packagejson"
  ],
  "importOrder": [
    "^react$",
    "^react-dom$",
    "^next$",
    "^next/",
    "<THIRD_PARTY_MODULES>",
    "^@/types$",
    "^@/config$",
    "^@/constants$",
    "^@/lib$",
    "^@/lib/(.*)$",
    "^@/hooks$",
    "^@/hooks/(.*)$",
    "^@/components/ui$",
    "^@/components/ui/(.*)$",
    "^@/components/layout$",
    "^@/components/layout/(.*)$",
    "^@/components/(.*)$",
    "^@/modules/(.*)$",
    "^@/stores$",
    "^@/stores/(.*)$",
    "^@/services$",
    "^@/services/(.*)$",
    "^@/utils$",
    "^@/utils/(.*)$",
    "^@/helpers$",
    "^@/helpers/(.*)$",
    "^@/validations$",
    "^@/validations/(.*)$",
    "^@/schemas$",
    "^@/schemas/(.*)$",
    "^@/middleware$",
    "^@/middleware/(.*)$",
    "^(.*)\\.css$",
    "^[./]"
  ],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true,
  "importOrderGroupNamespaceSpecifiers": true,
  "importOrderCaseInsensitive": true,
  "overrides": [
    {
      "files": ["*.json", "*.json5", "*.jsonc"],
      "options": {
        "tabWidth": 2,
        "printWidth": 80
      }
    },
    {
      "files": ["*.md", "*.mdx"],
      "options": {
        "printWidth": 80,
        "proseWrap": "always"
      }
    },
    {
      "files": ["*.yaml", "*.yml"],
      "options": {
        "tabWidth": 2,
        "singleQuote": false
      }
    },
    {
      "files": ["*.css", "*.scss", "*.sass"],
      "options": {
        "singleQuote": false
      }
    }
  ]
}