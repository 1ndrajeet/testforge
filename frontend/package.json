{
  "name": "testforge-v1.2",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:setup": "pnpm db:migrate && pnpm db:seed",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:write": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "pdb:generate": "dotenv -e .env.production -- drizzle-kit generate --config=drizzle.config.ts",
    "pdb:push": "dotenv -e .env.production -- drizzle-kit push --config=drizzle.config.ts",
    "pdb:studio": "dotenv -e .env.production -- drizzle-kit studio --config=drizzle.config.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.16",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "driver.js": "^1.6.0",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "radix-ui": "^1.5.0",
    "razorpay": "^2.9.6",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
    "react-icons": "^5.7.0",
    "react-to-print": "^3.3.0",
    "resend": "^6.16.0",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.1",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/xml2js": "^0.4.14",
    "@vitejs/plugin-react": "^6.0.3",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "^29.1.1",
    "knip": "^6.21.0",
    "prettier": "^3.8.4",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react-spinners": "^0.17.0",
    "tailwindcss": "^4",
